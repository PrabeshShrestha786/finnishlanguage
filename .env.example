# ─── DATABASE (FREE: neon.tech) ───────────────────────────────────────────────
# Sign up at neon.tech → create project → copy connection string
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/finnmate?sslmode=require"

# ─── REDIS (FREE: upstash.com) ────────────────────────────────────────────────
# Sign up at upstash.com → create Redis database → copy REST URL
REDIS_URL="rediss://default:password@your-db.upstash.io:6379"

# ─── AUTH ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_REFRESH_SECRET="another-long-random-string-for-refresh-tokens"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── GOOGLE OAUTH (FREE) ──────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# ─── AI (FREE: groq.com) ──────────────────────────────────────────────────────
# Sign up at console.groq.com → API Keys → Create key
# Free tier: 14,400 requests/day, 30 req/min — more than enough for dev
GROQ_API_KEY="gsk_your-groq-api-key"
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_WHISPER_MODEL="whisper-large-v3"

# ─── STORAGE (FREE: cloudinary.com) ───────────────────────────────────────────
# Sign up at cloudinary.com → Dashboard → copy credentials
# Free tier: 25GB storage, 25GB bandwidth/month
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ─── EMAIL (FREE: resend.com) ─────────────────────────────────────────────────
# Sign up at resend.com → API Keys
# Free tier: 100 emails/day, 3000/month
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="FinnMate <noreply@finnmate.app>"

# ─── PAYMENTS (STRIPE TEST MODE - FREE) ───────────────────────────────────────
# stripe.com → Developers → API keys (use test keys, no charge)
STRIPE_SECRET_KEY="sk_test_your-stripe-test-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"
STRIPE_PRO_PRICE_ID="price_test_pro_monthly"
STRIPE_PREMIUM_PRICE_ID="price_test_premium_monthly"
STRIPE_TEAM_PRICE_ID="price_test_team_monthly"

# ─── APP ──────────────────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"

# ─── TTS/STT NOTE ─────────────────────────────────────────────────────────────
# Text-to-Speech: Uses browser's built-in Web Speech API (free, no key needed)
# Speech-to-Text: Uses browser's Web Speech API + Groq Whisper as fallback
